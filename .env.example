# ============================================================
# ANDY SUBLIMADOS - VARIABLES DE ENTORNO
# ============================================================
# Copia este archivo a .env y completa con tus credenciales
# ============================================================

# SUPABASE
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# OPCIONAL: Para funciones del servidor
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# GEMINI AI (si usas el asistente de IA)
VITE_GEMINI_API_KEY=tu-gemini-api-key-aqui

# ============================================================
# INSTRUCCIONES:
# ============================================================
# 1. Ve a tu proyecto en Supabase
# 2. Settings > API > Project URL (copia en VITE_SUPABASE_URL)
# 3. Settings > API > anon public key (copia en VITE_SUPABASE_ANON_KEY)
# 4. Nunca subas el archivo .env a git (ya está en .gitignore)
# ============================================================
